#include <dt-bindings/leds/common.h>

/ {
	multi-led-ring0 {
		compatible = "leds-group-multicolor";
		label = "ring_rgb:0";
		color = <LED_COLOR_ID_RGB>;
		function = LED_FUNCTION_INDICATOR;
		leds = <&ring_red0>, <&ring_green0>, <&ring_blue0>;
	};

