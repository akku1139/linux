/dts-v1/;
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>

#include "mt8163-amazon.dtsi"
#include "mt8163-amazon-biscuit-consys.dtsi"
#include "mt8163-amazon-biscuit-leds.dtsi"

/ {
	model = "Amazon Echo Dot (2016)";
	compatible = "amazon,biscuit", "mediatek,mt8163";
	chassis-type = "embedded";

	/* Needed by stock bootloader */
	version = "evt";

	gpio-keys {
		compatible = "gpio-keys";
		pinctrl-names = "default";
		pinctrl-0 = <&gpio_keys_pins_default>;

		key-volume-up {
			label = "Volume Up";
			linux,code = <KEY_VOLUMEUP>;
			gpios = <&pio 50 GPIO_ACTIVE_LOW>;
			debounce-interval = <20>;
		};
	};

	dummy_1v8: regulator-fixed {
		compatible = "regulator-fixed";
		regulator-name = "dummy_1v8";
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		regulator-boot-on;
		regulator-always-on;
	};

	sound {
		compatible = "amazon,mt8163-biscuit-tlv320aic32x4";

		pinctrl-0 = <&sound_pins_default>;
		pinctrl-names = "default";

		mediatek,platform = <&afe>;
		mediatek,audio-codec = <&tlv320aic32x4>;

		accdet-gpio = <&pio 26 GPIO_ACTIVE_HIGH>;
		dacmux-gpio = <&pio 124 GPIO_ACTIVE_HIGH>;
		extamp-gpio = <&pio 122 GPIO_ACTIVE_HIGH>;
	};
};

&{/soc} {
	isp_mclk: clock-controller@15008000 {
		compatible = "mediatek,isp-mclk";
		reg = <0 0x15008000 0 0x1000>;
		#clock-cells = <0>;
		clocks = <&imgsys CLK_IMG_SEN_TG>,
			 <&imgsys CLK_IMG_SEN_CAM>;
		clock-names = "sen_tg", "sen_cam";
		power-domains = <&spm MT8163_POWER_DOMAIN_DISP>,
				<&spm MT8163_POWER_DOMAIN_ISP>;
		power-domain-names = "mm", "isp";
		assigned-clocks = <&topckgen CLK_TOP_CAMTG_SEL>;
		assigned-clock-parents = <&topckgen CLK_TOP_UNIV_48M>;
	};
};

&afe {
	status = "okay";
};

&gpu {
	status = "disabled";
};

&i2c0 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c0_pins_default>;
	clock-frequency = <100000>;
	status = "okay";

	tsl2584tsv@29 {
		compatible = "amstaos,tsl2584tsv";
		reg = <0x29>;
		als_name = "taos_als";
		autozero-period-ms = <300000>;
	};

	tsl2540@39 {
		compatible = "amstaos,tsl2540";
		reg = <0x39>;
		als_name = "taos_als";
		persist = <18>;
		als_gain = <3>;
		als_gain_factor = <1>;
		als_deltap = <10>;
		als_time = <123>;
		d_factor = <47540>;
		ch0_coef0 = <1000>;
		ch1_coef0 = <305>;
		ch0_coef1 = <118>;
		ch1_coef1 = <21>;
		az_iterations = <126>;
		als_can_wake = <0>;
		boot-on;
	};
};

&i2c2 {
	pinctrl-names = "default";
	pinctrl-0 = <&i2c2_pins_default>;
	clock-frequency = <400000>;
	status = "okay";

	tlv320aic32x4: tlv320aic32x4@18 {
		compatible = "ti,tlv320aic32x4";
		reg = <0x18>;
		pinctrl-0 = <&codec_pins_default>;
		pinctrl-names = "default";
		reset-gpios = <&pio 51 GPIO_ACTIVE_LOW>;
		clocks = <&isp_mclk>;
		clock-names = "mclk";
		iov-supply = <&mt6323_vgp1_reg>;
		ldoin-supply = <&mt6323_vmch_reg>;
	};
};

&keypad {
	linux,keymap = <MATRIX_KEY(0x00, 0x00, KEY_ASSISTANT)
			MATRIX_KEY(0x00, 0x01, KEY_VOLUMEDOWN)>;

	keypad,num-rows = <1>;
	keypad,num-columns = <2>;
	debounce-delay-ms = <20>;

	pinctrl-names = "default";
	pinctrl-0 = <&keypad_pins_default>;

	status = "okay";
};

&mfgcfg {
	status = "disabled";
};

&mt6323_vcamaf_reg {
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <1800000>;
};

&mt6323_vgp1_reg {
	regulator-min-microvolt = <3300000>;
	regulator-max-microvolt = <3300000>;
};

&mt6323_vusb_reg {
	regulator-always-on;
};

&spi {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&spi_pins_default>;

	audio-codec@0 {
		compatible = "amazon,dough-fpga";
		reg = <0>;
		pinctrl-0 = <&fpga_pins_init>,
			    <&i2s_pins_init>;
		pinctrl-1 = <&i2s_pins_default>;
		pinctrl-names = "init", "default";
		spi-max-frequency = <50000000>;
		reset-gpios = <&pio 43 GPIO_ACTIVE_LOW>;
		/* TODO: Find the real vccio0... */
		vccio0-supply = <&dummy_1v8>;
		vccio2-supply = <&mt6323_vcamaf_reg>;
	};
};

&thermal {
	status = "disabled";
};

&u2phy0 {
	status = "okay";
};

&usb0 {
	/* No 5V supply for OTG support. */
	dr_mode = "peripheral";
	status = "okay";
};

&vdecsys {
	status = "disabled";
};

&vencsys {
	status = "disabled";
};

&pio {
	sound_pins_default: sound-pins-default {
		pins-accdet {
			pinmux = <MT8163_PIN_26_EINT4__FUNC_GPIO26>;
			bias-disable;
		};

		pins-dacmux {
			pinmux = <MT8163_PIN_124_MSDC1_DAT1__FUNC_GPIO124>;
			output-low;
		};

		pins-extamp {
			pinmux = <MT8163_PIN_122_MSDC1_CLK__FUNC_GPIO122>;
			output-low;
		};

		pins-mclk {
			pinmux = <MT8163_PIN_119_CMMCLK__FUNC_CMMCLK>;
			drive-strength = <MTK_DRIVE_4mA>;
		};
	};

	i2s_pins_init: i2s-pins-init {
		pins-i2s {
			pinmux = <MT8163_PIN_72_I2S_DATA_IN__FUNC_GPIO72>,
				 <MT8163_PIN_73_I2S_LRCK__FUNC_GPIO73>,
				 <MT8163_PIN_74_I2S_BCK__FUNC_GPIO74>;
		};
	};

	i2s_pins_default: i2s-pins-default {
		pins-i2s {
			pinmux = <MT8163_PIN_72_I2S_DATA_IN__FUNC_I2S1_DO>,
				 <MT8163_PIN_73_I2S_LRCK__FUNC_I2S1_LRCK>,
				 <MT8163_PIN_74_I2S_BCK__FUNC_I2S1_BCK>;
			drive-strength = <MTK_DRIVE_4mA>;
		};
	};

	fpga_pins_init: fpga-pins-init {
		pins-reset {
			pinmux = <MT8163_PIN_43_EINT11__FUNC_GPIO43>;
		};
	};

	codec_pins_default: codec-pins {
		pins {
			pinmux = <MT8163_PIN_51_EINT19__FUNC_GPIO51>;
		};
	};

	gpio_keys_pins_default: gpio-keys-pins {
		pins {
			pinmux = <MT8163_PIN_50_EINT18__FUNC_GPIO50>;
			bias-pull-up;
			input-enable;
		};
	};

	keypad_pins_default: keypad-pins {
		pins {
			pinmux = <MT8163_PIN_36_KPCOL0__FUNC_KPCOL0>,
					 <MT8163_PIN_37_KPCOL1__FUNC_KPCOL1>;
			input-enable;
		};
	};

	i2c0_pins_default: i2c0-pins {
		pins1 {
			pinmux = <MT8163_PIN_75_SDA0__FUNC_SDA0_0>,
				 <MT8163_PIN_76_SCL0__FUNC_SCL0_0>;
			bias-disable;
		};
	};

	i2c2_pins_default: i2c2-pins {
		pins {
			pinmux = <MT8163_PIN_77_SDA2__FUNC_SDA2_0>,
				 <MT8163_PIN_78_SCL2__FUNC_SCL2_0>;
			bias-disable;
		};
	};

	spi_pins_default: spi-pins {
		pins {
			pinmux = <MT8163_PIN_53_SPI_CS__FUNC_SPI_CSB>,
				 <MT8163_PIN_54_SPI_CK__FUNC_SPI_CLK>,
				 <MT8163_PIN_55_SPI_MI__FUNC_SPI_MI>,
				 <MT8163_PIN_56_SPI_MO__FUNC_SPI_MO>;
			bias-disable;
			drive-strength = <MTK_DRIVE_2mA>;
		};
	};
};
