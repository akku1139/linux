#include <dt-bindings/gpio/gpio.h>
#include "mt6757.dtsi"
#include "mt6351.dtsi"

/ {
	aliases {
		serial0 = &uart0;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	memory@40000000 {
		device_type = "memory";
		reg = <0 0x40000000 0 0x20000000>;
	};

	reserved_memory: reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		/* Reserve memory for ATF + its ramdump region */
		atf-reserved-memory@50e00000 {
			reg = <0 0x50e00000 0 0x14000>;
			no-map;
		};

		atf-ramdump-memory@50e14000 {
			reg = <0 0x50e14000 0 0x2c000>;
			no-map;
		};

		/* Use the same ramoops region as downstream */
		ramoops@44410000 {
			compatible = "ramoops";
			reg = <0x0 0x44410000 0x0 0xe0000>;
			console-size = <0x10000>;
			record-size = <0x10000>;
		};
	};
};

&i2c1 {
	status = "okay";
	pinctrl-names = "default";
	pinctrl-0 = <&i2c1_pins_default>;
	clock-frequency = <400000>;

	bq25896: charger@6b {
		compatible = "ti,bq25896";
		reg = <0x6b>;
		interrupt-parent = <&pio>;
		interrupts = <101 IRQ_TYPE_LEVEL_LOW>;
		ti,battery-regulation-voltage = <4352000>;
		ti,charge-current = <2048000>;
		ti,termination-current = <128000>;
		ti,precharge-current = <128000>;
		ti,minimum-sys-voltage = <3500000>;
		ti,boost-voltage = <4998000>;
		ti,boost-max-current = <1400000>;
		ti,use-ilim-pin;
		ti,thermal-regulation-threshold = <120>;

		bq25896_vbus: usb-otg-vbus { };
		bq25896_vsys: vsys { };
	};
};

&mt6351_pmic {
	interrupts-extended = <&pio 150 IRQ_TYPE_LEVEL_HIGH>;
};

&uart0 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart0_pins_default>;
	status = "okay";
};

&pio {
	i2c1_pins_default: i2c1-pins {
		pins-bus {
			pinmux = <PINMUX_GPIO91__FUNC_SDA1>,
				 <PINMUX_GPIO94__FUNC_SCL1>;
			bias-disable;
		};
	};

	uart0_pins_default: uart0-pins {
		pins-rx {
			pinmux = <PINMUX_GPIO105__FUNC_URXD0>;
			input-enable;
			bias-pull-up;
		};
		pins-tx {
			pinmux = <PINMUX_GPIO106__FUNC_UTXD0>;
		};
	};
};
