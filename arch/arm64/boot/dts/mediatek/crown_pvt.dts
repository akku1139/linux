/dts-v1/;

#include <dt-bindings/input/input.h>
#include "crown.dtsi"

/ {
	model = "Amazon Crown Pvt";
	compatible = "amzn,crown-pvt";
	version = "pvt";
};

&kd_camera_hw1 {
	reg-vcamd-supply = <&mt6323_vgp2_reg>;
	cam-pwr-en-gpios = <&pio 45 GPIO_ACTIVE_HIGH>;
};

&touch {
	vtouch-supply = <&mt6323_vgp1_reg>;
};

&pwrap {
	pmic: mt6323 {
		regulators {
			mt6323_vgp1_reg: ldo_vgp1 {
				regulator-min-microvolt = <3300000>;
				regulator-max-microvolt = <3300000>;
				regulator-always-on;
				regulator-boot-on;
			};

			mt6323_vgp2_reg: ldo_vgp2 {
				regulator-min-microvolt = <1200000>;
				regulator-max-microvolt = <3300000>;
				/delete-property/ regulator-always-on;
				/delete-property/ regulator-boot-on;
			};
		};
	};
};

&gpio_keys {
	camera_lens_cover {
		label = "Camera Lens Cover";
		gpios = <&pio 142 GPIO_ACTIVE_LOW>;
		linux,input-type = <EV_SW>;
		linux,code = <SW_CAMERA_LENS_COVER>;
	};
};

&cust_als {
	white_als_range = <4>;	/* White device als range change to 4 */
};

&pwm {
	is_two_point_cal_enabled = <1>;
};
