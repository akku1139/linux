/dts-v1/;

#include <dt-bindings/input/input.h>
#include "cronos.dtsi"

/ {
	version = "evt";
};

&kd_camera_hw1 {
        /delete-property/ reg-vcamd-supply;
};

&touch {
	vtouch-supply = <&mt6323_vgp1_reg>;
};

&pwrap {
	pmic: mt6323 {
		regulators {
			mt6323_vgp1_reg: ldo_vgp1 {
				regulator-min-microvolt = <3300000>;
				regulator-max-microvolt = <3300000>;
				regulator-always-on;
				regulator-boot-on;
			};
		};
	};
};

&gpio_keys {
	camera_lens_cover {
		label = "Camera Lens Cover";
		debounce-interval = <50>;
		gpios = <&pio 142 GPIO_ACTIVE_LOW>;
		linux,input-type = <EV_SW>;
		linux,code = <SW_CAMERA_LENS_COVER>;
	};
};

&gpio_privacy {
	button_event {
		gpios = <&pio 47 GPIO_ACTIVE_LOW>;
	};
};

&cust_als {
	is_supported_two_point_als_cali = <1>;
};

&i2c0 {
	tlv320aic3101@19 {
		status = "disabled";
	};
};

&i2c2 {
	/delete-node/ focaltech_ts@38;
};

&accdet {
	status = "disabled";
};

&led6 {
	custom-brightness-table = <2 1 0
				249 4 (-8)
				255 6 (-507)>;
};

&pmicmt6323 {
	io-channels = <&auxadc 15>;
	io-channel-names = "power-channel";
};

&skin_virtual_sensor {
	compatible = "amazon,virtual_sensor";
	#thermal-sensor-cells = <0>;

	zone-list {
		zone-names = "therm0_s", "therm1_s", "therm2_s", "mtktscpu";
		therm0_s = <0 32300 417 530 (-40000) 125000>;
		therm1_s = <0 0 0 0 (-40000) 125000>;
		therm2_s = <0 0 0 0 (-40000) 125000>;
		mtktscpu = <0 0 0 0 0 0>;
	};
};

&case_virtual_sensor {
	compatible = "amazon,virtual_sensor";
	#thermal-sensor-cells = <0>;

	zone-list {
		zone-names = "therm0_s", "therm1_s", "therm2_s", "mtktscpu";
		therm0_s = <0 0 0 0 (-40000) 125000>;
		therm1_s = <0 0 0 0 (-40000) 125000>;
		therm2_s = <0 0 0 0 (-40000) 125000>;
		mtktscpu = <0 0 100 1000 0 0>;
	};
};

&dcorner_virtual_sensor {
	compatible = "amazon,virtual_sensor";
	#thermal-sensor-cells = <0>;

	zone-list {
		zone-names = "therm0_s", "therm1_s", "therm2_s", "mtktscpu";
		therm0_s = <1 50300 100 3060 (-40000) 125000>;
		therm1_s = <0 0 0 0 (-40000) 125000>;
		therm2_s = <1 74300 100 (-2230) (-40000) 125000>;
		mtktscpu = <0 0 0 0 0 0>;
	};
};

&cpu_virtual_sensor {
	compatible = "amazon,virtual_sensor";
	#thermal-sensor-cells = <0>;

	zone-list {
		zone-names = "therm0_s", "therm1_s", "therm2_s", "mtktscpu";
		therm0_s = <0 0 0 0 (-40000) 125000>;
		therm1_s = <0 0 0 0 (-40000) 125000>;
		therm2_s = <0 0 0 0 (-40000) 125000>;
		mtktscpu = <0 0 800 1000 0 0>;
	};
};
