	wcn: wcn {
		compatible = "sprd,ums9230-wcn";
		dma-ranges = <0 0x0 0x87000000 0x00800000>;
		#address-cells = <1>;
		#size-cells = <1>;

		sprd,syscon-ap-pub-apb = <&pub_apb_regs>;
		sprd,syscon-ap-aon-apb = <&aon_apb_regs>;
		sprd,syscon-wcn-aon-ahb = <&wcncp_aon_ahb_regs>;
		sprd,syscon-wcn-aon-apb = <&wcncp_aon_apb_regs>;

		resets = <&pmu_gate RESET_PMU_APB_WCN_SOFT_RST>;
		power-domains = <&pmu UMS9230_POWER_DOMAIN_WCN>;

		wakeup-source;

		status = "disabled";

		btwf {
			dma-ranges;
			#address-cells = <1>;
			#size-cells = <1>;

			sprd,syscon-wcn-ahb = <&wcncp_btwf_ahb_regs>;

			memory-region = <&wcn_btwf_region>;
			sprd,sync-region = <&wcn_btwf_sync_region>;
			firmware-name = "sprd/wcnmodem.bin";

			sipc {
				#address-cells = <1>;
				#size-cells = <0>;

				label = "wcn";

				mboxes = <&mailbox 8>;

				memory-region = <&sipc_wcn_btwf_region>;

				channel@4 {
					reg = <4>;
					sprd,channel-type = "sbuf";
					sprd,channel-name = "wcn_misc";
					#address-cells = <1>;
					#size-cells = <0>;
					sprd,num-buffers = <16>;
					sprd,tx-buf-size = <0x2400>;
					sprd,rx-buf-size = <0x2400>;

					atcmd@5 {
						reg = <5>, <5>;
						sprd,channel-name = "wcn_atcmd";
					};

					bluetooth@10 {
						compatible = "sprd,bluetooth-sipc";
						reg = <10>, <11>;
						sprd,channel-name = "wcn_bt";
						/* filled in by bootloader */
						local-bd-address = [00 00 00 00 00 00];
					};

					fm@13 {
						reg = <13>, <14>;
						sprd,channel-name = "wcn_fm";
					};
				};

				channel@5 {
					reg = <5>;
					sprd,channel-type = "sbuf";
					sprd,channel-name = "wcn_log";
					#address-cells = <1>;
					#size-cells = <0>;
					sprd,num-buffers = <1>;
					sprd,tx-buf-size = <0x0>;
					sprd,rx-buf-size = <0x1000>;

					log@0 {
						reg = <0>, <0>;
						sprd,channel-name = "wcn_log0";
					};
				};

				channel@7 {
					compatible = "sprd,umw2631-wlan", "sprd,sc2355-wlan";
					reg = <7>;
					sprd,channel-type = "sblock";
					sprd,channel-name = "wcn_wifi_cmd";
					sprd,tx-blk-count = <4>;
					sprd,tx-blk-size = <2048>;
					sprd,rx-blk-count = <8>;
					sprd,rx-blk-size = <2048>;
					memory-region = <&wifi_dma_region>;
					/* filled in by bootloader */
					local-mac-address = [00 00 00 00 00 00];
				};

				channel@8 {
					reg = <8>;
					sprd,channel-type = "sblock";
					sprd,channel-name = "wcn_wifi_data0";
					sprd,tx-blk-count = <512>;
					sprd,tx-blk-size = <512>;
					sprd,rx-blk-count = <512>;
					sprd,rx-blk-size = <1024>;
				};

				channel@9 {
					reg = <9>;
					sprd,channel-type = "sblock";
					sprd,channel-name = "wcn_wifi_data1";
					sprd,tx-blk-count = <8>;
					sprd,tx-blk-size = <1664>;
					sprd,rx-blk-count = <64>;
					sprd,rx-blk-size = <1664>;
				};

				channel@11 {
					reg = <11>;
					sprd,channel-type = "sbuf";
					sprd,channel-name = "wcn_loopcheck";
					#address-cells = <1>;
					#size-cells = <0>;
					sprd,num-buffers = <1>;
					sprd,tx-buf-size = <0x400>;
					sprd,rx-buf-size = <0x400>;

					loopcheck@0 {
						reg = <0>, <0>;
						sprd,channel-name = "wcn_loopcheck0";
					};
				};

				channel@12 {
					reg = <12>;
					sprd,channel-type = "sbuf";
					sprd,channel-name = "wcn_assert";
					#address-cells = <1>;
					#size-cells = <0>;
					sprd,num-buffers = <1>;
					sprd,tx-buf-size = <0x400>;
					sprd,rx-buf-size = <0x400>;

					assert@0 {
						reg = <0>, <0>;
						sprd,channel-name = "wcn_assert0";
					};
				};
			};
		};

		gnss_proc: gnss {
			#address-cells = <1>;
			#size-cells = <1>;

			sprd,syscon-wcn-ahb = <&wcncp_gnss_ahb_regs>;

			memory-region = <&wcn_gnss_region>;
			sprd,sync-region = <&wcn_gnss_sync_region>;
			firmware-name = "sprd/gnssmodem.bin";
		};
	};

	ext_26m: clk-26m {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <26000000>;
		clock-output-names = "ext-26m";
	};

	ext_32k: clk-32k {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <32768>;
		clock-output-names = "ext-32k";
	};

	rco_100m: clk-100m {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <100000000>;
		clock-output-names = "rco-100m";
	};

	dphy_250m: dphy-250m {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <250000000>;
		clock-output-names = "dphy-250m";
	};

	dphy_333m3: dphy-333m3 {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <333300000>;
		clock-output-names = "dphy-333m3";
	};
};
