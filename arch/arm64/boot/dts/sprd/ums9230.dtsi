		mailbox: mailbox@641c0000 {
			compatible = "sprd,ums9230-mailbox";
			reg = <0x641c0000 0x10000>,
			      <0x641d0000 0x10000>;
			#mbox-cells = <1>;
			clocks = <&aon_gate CLK_MBOX_EB>;
			clock-names = "enable";
			interrupts = <GIC_SPI 82 IRQ_TYPE_LEVEL_HIGH>,
				     <GIC_SPI 83 IRQ_TYPE_LEVEL_HIGH>,
				     <GIC_SPI 84 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-names = "inbox", "outbox", "supp-outbox";
		};

		adi_bus: spi@64200000 {
			compatible = "sprd,ums9230-adi", "sprd,ums512-adi";
			reg = <0x64200000 0x100000>;
			#address-cells = <1>;
			#size-cells = <0>;
			sprd,hw-channels = <2 0x18cc>, <3 0x18cc>,
					   <13 0x1854>, <15 0x1874>,
					   <17 0x1844>, <19 0x1844>,
					   <21 0x1864>, <30 0x1820>,
					   <32 0x197c>, <33 0x1988>,
					   <35 0x19b8>, <39 0x19ac>;
		};

		pwm: pwm@643f0000 {
			compatible = "sprd,ums9230-pwm", "sprd,ums512-pwm";
			reg = <0x643f0000 0x10000>;
			clocks = <&aon_clk CLK_PWM0>, <&aon_gate CLK_PWM0_EB>,
				 <&aon_clk CLK_PWM1>, <&aon_gate CLK_PWM1_EB>,
				 <&aon_clk CLK_PWM2>, <&aon_gate CLK_PWM2_EB>,
				 <&aon_clk CLK_PWM3>, <&aon_gate CLK_PWM3_EB>;
			clock-names = "pwm0", "enable0",
				      "pwm1", "enable1",
				      "pwm2", "enable2",
				      "pwm3", "enable3";
			assigned-clocks = <&aon_clk CLK_PWM0>,
					  <&aon_clk CLK_PWM1>,
					  <&aon_clk CLK_PWM2>,
					  <&aon_clk CLK_PWM3>;
			assigned-clock-parents = <&ext_26m>,
						 <&ext_26m>,
						 <&ext_26m>,
						 <&ext_26m>;
			#pwm-cells = <2>;
		};

		/*timer@64470000 {
			compatible = "sprd,ums9230-timer", "sprd,sc9860-timer";
			reg = <0x64470000 0x20>;
			interrupts = <GIC_SPI 71 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&ext_32k>;
		};*/

		timer@64470020 {
			compatible = "sprd,ums9230-suspend-timer", "sprd,sc9860-suspend-timer";
			reg = <0x64470020 0x20>;
			clocks = <&ext_32k>;
		};

		ap_thm0: thermal@644b0000 {
			compatible = "sprd,ums9230-thermal", "sprd,ums512-thermal";
			reg = <0x644b0000 0x10000>;
			clocks = <&aon_gate CLK_THM0_EB>;
			clock-names = "enable";
			#thermal-sensor-cells = <1>;
			nvmem-cells = <&thm0_sign>, <&thm0_ratio>;
			nvmem-cell-names = "thm_sign_cal", "thm_ratio_cal";
			#address-cells = <1>;
			#size-cells = <0>;

			sensor@0 {
				reg = <0>;
				nvmem-cells = <&thm0_sen0>;
				nvmem-cell-names = "sen_delta_cal";
			};

			sensor@1 {
				reg = <1>;
				nvmem-cells = <&thm0_sen1>;
				nvmem-cell-names = "sen_delta_cal";
			};

			sensor@2 {
				reg = <2>;
				nvmem-cells = <&thm0_sen2>;
				nvmem-cell-names = "sen_delta_cal";
			};

			sensor@3 {
				reg = <3>;
				nvmem-cells = <&thm0_sen3>;
				nvmem-cell-names = "sen_delta_cal";
			};

			sensor@4 {
				reg = <4>;
				nvmem-cells = <&thm0_sen4>;
				nvmem-cell-names = "sen_delta_cal";
			};

			sensor@5 {
				reg = <5>;
				nvmem-cells = <&thm0_sen5>;
				nvmem-cell-names = "sen_delta_cal";
			};
		};

		ap_thm2: thermal@644d0000 {
			compatible = "sprd,ums9230-thermal", "sprd,ums512-thermal";
			reg = <0x644d0000 0x10000>;
			clocks = <&aon_gate CLK_THM2_EB>;
			clock-names = "enable";
			#thermal-sensor-cells = <1>;
			nvmem-cells = <&thm2_sign>, <&thm2_ratio>;
			nvmem-cell-names = "thm_sign_cal", "thm_ratio_cal";
			#address-cells = <1>;
			#size-cells = <0>;

			sensor@0 {
				reg = <0>;
				nvmem-cells = <&thm2_sen0>;
				nvmem-cell-names = "sen_delta_cal";
			};

			sensor@1 {
				reg = <1>;
				nvmem-cells = <&thm2_sen1>;
				nvmem-cell-names = "sen_delta_cal";
			};

			sensor@2 {
				reg = <2>;
				nvmem-cells = <&thm2_sen2>;
				nvmem-cell-names = "sen_delta_cal";
			};

			sensor@3 {
				reg = <3>;
				nvmem-cells = <&thm2_sen3>;
				nvmem-cell-names = "sen_delta_cal";
			};

			sensor@4 {
				reg = <4>;
				nvmem-cells = <&thm2_sen4>;
				nvmem-cell-names = "sen_delta_cal";
			};
		};

		watchdog@644e0000 {
			compatible = "sprd,ums9230-wdt", "sprd,sp9860-wdt";
			reg = <0x644e0000 0x1000>;
			interrupts = <GIC_SPI 79 IRQ_TYPE_LEVEL_HIGH>;
			timeout-sec = <12>;
			clocks = <&aon_gate CLK_APCPU_WDG_EB>,
				 <&aon_gate CLK_AC_WDG_RTC_EB>;
			clock-names = "enable", "rtc_enable";
		};

		anlg_phy_g0_regs: syscon@64550000 {
                        compatible = "sprd,ums9230-glbregs", "syscon", "simple-mfd";
                        reg = <0x64550000 0x10000>;
			#address-cells = <1>;
			#size-cells = <1>;
			ranges = <0x0 0x64550000 0x10000>;

			dpll0: clock-controller@0 {
				compatible = "sprd,ums9230-g0-pll";
				reg = <0x0 0x100>;
				#clock-cells = <1>;
			};
                };

		anlg_phy_g1_regs: syscon@64560000 {
                        compatible = "sprd,ums9230-glbregs", "syscon", "simple-mfd";
                        reg = <0x64560000 0x10000>;
			#address-cells = <1>;
			#size-cells = <1>;
			ranges = <0x0 0x64560000 0x10000>;

			pll0: clock-controller@0 {
				compatible = "sprd,ums9230-g1-pll";
				reg = <0x0 0x100>;
				clocks = <&ext_26m>;
				clock-names = "ext-26m";
				#clock-cells = <1>;
			};
                };

		anlg_phy_g2_regs: syscon@64570000 {
                        compatible = "sprd,ums9230-glbregs", "syscon", "simple-mfd";
                        reg = <0x64570000 0x10000>;
			#address-cells = <1>;
			#size-cells = <1>;
			ranges = <0x0 0x64570000 0x10000>;

			hsphy: phy@0 {
				compatible = "sprd,ums9230-hsphy";
				reg = <0x0 0x3000>;
				sprd,syscon-aon-apb = <&aon_apb_regs>;
				#phy-cells = <0>;

				status = "disabled";
			};
                };

		anlg_phy_g3_regs: syscon@64580000 {
                        compatible = "sprd,ums9230-glbregs", "syscon", "simple-mfd";
                        reg = <0x64580000 0x10000>;
			#address-cells = <1>;
			#size-cells = <1>;
			ranges = <0x0 0x64580000 0x10000>;

			mpll1: clock-controller@0 {
				compatible = "sprd,ums9230-g3-pll";
				reg = <0x0 0x100>;
				clocks = <&ext_26m>;
				clock-names = "ext-26m";
				#clock-cells = <1>;
			};
                };

		anlg_phy_gc_regs: syscon@645a0000 {
                        compatible = "sprd,ums9230-glbregs", "syscon", "simple-mfd";
                        reg = <0x645a0000 0x10000>;
			#address-cells = <1>;
			#size-cells = <1>;
			ranges = <0x0 0x645a0000 0x10000>;

			pll1: clock-controller@0 {
				compatible = "sprd,ums9230-gc-pll";
				reg = <0x0 0x100>;
				clocks = <&ext_26m>;
				clock-names = "ext-26m";
				#clock-cells = <1>;
			};
                };

		anlg_phy_g10_regs: syscon@645b0000 {
			compatible = "sprd,ums9230-glbregs", "syscon", "simple-mfd";
			reg = <0x645b0000 0x10000>;
		};

		pinctrl: pinctrl@64710000 {
			compatible = "sprd,ums9230-pinctrl";
			reg = <0x64710000 0x10000>;
		};

		usb: usb@64900000 {
			compatible = "sprd,ums9230-musb", "sprd,musb";
			reg = <0x64900000 0x2000>;
			interrupts = <GIC_SPI 69 IRQ_TYPE_LEVEL_HIGH>;
			interrupt-names = "mc";
			clocks = <&aon_gate CLK_OTG_UTMI_EB>;
			phys = <&hsphy>;

			status = "disabled";
		};

		hwlock: hwspinlock@64910000 {
			compatible = "sprd,hwspinlock-r3p0";
			reg = <0x64910000 0x1000>;
			#hwlock-cells = <1>;
			clocks = <&aon_gate CLK_SPLK_EB>;
			clock-names = "enable";
		};

		modem: modem@65003400 {
			compatible = "sprd,ums9230-modem";
			reg = <0x65003400 0x1000>;

			sprd,syscon-aon-apb = <&aon_apb_regs>;

			resets = <&pmu_gate RESET_PMU_APB_PUBCP_SOFT_RST>;
			power-domains = <&pmu UMS9230_POWER_DOMAIN_PUBCP>;

			memory-region = <&modem_region>;
			firmware-name = "sprd/l_modem.bin";

			wakeup-source;

			status = "disabled";

			sipc {
				#address-cells = <1>;
				#size-cells = <0>;

				label = "modem";

				mboxes = <&mailbox 2>;

				memory-region = <&sipc_modem_region>;

				sprd,sipx-dl-blk-count = <512>;
				sprd,sipx-dl-ack-count = <64>;
				sprd,sipx-ul-blk-count = <512>;
				sprd,sipx-ul-ack-count = <0>;

				channel@2 {
					reg = <2>;
					sprd,channel-type = "sblock";
					sprd,channel-name = "imsbr_data";
					sprd,rx-blk-count = <64>;
					sprd,rx-blk-size = <1600>;
					sprd,tx-blk-count = <64>;
					sprd,tx-blk-size = <1600>;
				};

				channel@3 {
					reg = <3>;
					sprd,channel-type = "sblock";
					sprd,channel-name = "imsbr_ctrl";
					sprd,rx-blk-count = <64>;
					sprd,rx-blk-size = <1600>;
					sprd,tx-blk-count = <64>;
					sprd,tx-blk-size = <1600>;
				};

				channel@4 {
					reg = <4>;
					sprd,channel-type = "sbuf";
					sprd,channel-name = "lte_misc";
					#address-cells = <1>;
					#size-cells = <0>;
					sprd,num-buffers = <20>;
					sprd,tx-buf-size = <0x1000>;
					sprd,rx-buf-size = <0x1000>;

					nv@1 {
						compatible = "sprd,spipe-nv";
						reg = <1>, <1>;
						sprd,channel-name = "lte_nv";
					};

					timesync@8 {
						compatible = "sprd,spipe-time";
						reg = <8>, <8>;
						sprd,channel-name = "lte_time";
					};

					/* channel 15 is used for "SRMI" */
				};

				channel@6 {
					reg = <6>;
					sprd,channel-type = "sbuf";
					sprd,channel-name = "lte_at";
					#address-cells = <1>;
					#size-cells = <0>;
					sprd,num-buffers = <32>;
					sprd,tx-buf-size = <0x800>;
					sprd,rx-buf-size = <0x800>;

					/* SIM 0 port with indications */
					atcmd@0 {
						compatible = "sprd,spipe-at";
						reg = <0>, <0>;
						sprd,channel-name = "lte_at0";
					};

					/* SIM 1 port with indications */
					atcmd@3 {
						compatible = "sprd,spipe-at";
						reg = <3>, <3>;
						sprd,channel-name = "lte_at3";
					};
				};

				channel@7 {
					compatible = "sprd,seth";
					reg = <7>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte0";
				};

				channel@8 {
					compatible = "sprd,seth";
					reg = <8>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte1";
				};

				channel@9 {
					compatible = "sprd,seth";
					reg = <9>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte2";
				};

				channel@18 {
					compatible = "sprd,seth";
					reg = <18>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte3";
				};

				channel@19 {
					compatible = "sprd,seth";
					reg = <19>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte4";
				};

				channel@20 {
					compatible = "sprd,seth";
					reg = <20>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte5";
				};

				channel@21 {
					reg = <21>;
					sprd,channel-type = "sbuf";
					sprd,channel-name = "lte_diag";
					#address-cells = <1>;
					#size-cells = <0>;
					sprd,num-buffers = <1>;
					sprd,tx-buf-size = <0x8000>;
					sprd,rx-buf-size = <0x20000>;

					diag@0 {
						compatible = "sprd,spipe-diag";
						reg = <0>, <0>;
						sprd,channel-name = "lte_diag0";
					};
				};

				/* channel 23 is "dual sim plug" */

				channel@24 {
					compatible = "sprd,seth";
					reg = <24>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte6";
				};

				channel@25 {
					compatible = "sprd,seth";
					reg = <25>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte7";
				};

				channel@26 {
					compatible = "sprd,seth";
					reg = <26>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte8";
				};

				channel@27 {
					compatible = "sprd,seth";
					reg = <27>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte9";
				};

				channel@28 {
					compatible = "sprd,seth";
					reg = <28>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte10";
				};

				channel@29 {
					compatible = "sprd,seth";
					reg = <29>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte11";
				};

				channel@30 {
					compatible = "sprd,seth";
					reg = <30>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte12";
				};

				channel@31 {
					compatible = "sprd,seth";
					reg = <31>;
					sprd,channel-type = "sipx";
					sprd,channel-name = "seth_lte13";
				};

				/* channel 41 is modem DVFS */
			};
		};
	};

	sound: sound {
		compatible = "sprd,ums9230-audio-card";
		sprd,pcm-platform = <&sprd_pcm>;
		memory-region = <&audio_dma_region>;

		status = "disabled";
	};

	modem_dai: sound-modem-codec {
		compatible = "sprd,ums9230-modem-dai", "option,gtm601";
		#sound-dai-cells = <0>;
		sound-name-prefix = "Modem DAI";

		status = "disabled";
	};

	thermal-zones {
		cputop0-thermal {
			polling-delay-passive = <250>;

			thermal-sensors = <&ap_thm0 0>;

			trips {
				cputop0_alert0: trip-point0 {
					temperature = <70000>;
					hysteresis = <1000>;
					type = "passive";
				};

				cputop0_critical: cpu-crit {
					temperature = <110000>;
					hysteresis = <2000>;
					type = "critical";
				};
			};

			cooling-maps {
				map0 {
					trip = <&cputop0_alert0>;
					cooling-device = <&cpu0 THERMAL_NO_LIMIT THERMAL_NO_LIMIT>,
							 <&cpu1 THERMAL_NO_LIMIT THERMAL_NO_LIMIT>,
							 <&cpu2 THERMAL_NO_LIMIT THERMAL_NO_LIMIT>,
							 <&cpu3 THERMAL_NO_LIMIT THERMAL_NO_LIMIT>,
							 <&cpu4 THERMAL_NO_LIMIT THERMAL_NO_LIMIT>,
							 <&cpu5 THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
				};
			};
		};

		ank0-thermal {
			polling-delay-passive = <250>;

			thermal-sensors = <&ap_thm0 1>;

			trips {
				cpu0_alert0: trip-point0 {
					temperature = <70000>;
					hysteresis = <1000>;
					type = "passive";
				};

				cpu0_critical: cpu-crit {
					temperature = <110000>;
					hysteresis = <2000>;
					type = "critical";
				};
			};

			cooling-maps {
				map0 {
					trip = <&cpu0_alert0>;
					cooling-device = <&cpu0 THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
				};
			};
		};

		ank1-thermal {
			polling-delay-passive = <250>;

			thermal-sensors = <&ap_thm0 2>;

			trips {
				cpu1_alert0: trip-point0 {
					temperature = <70000>;
					hysteresis = <1000>;
					type = "passive";
				};

				cpu1_critical: cpu-crit {
					temperature = <110000>;
