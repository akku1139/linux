			reg = <0x641000c0 0x20>,
			      <0x641100c0 0x20>,
			      <0x641200c0 0x20>,
			      <0x641300c0 0x20>,
			      <0x641400c0 0x20>,
			      <0x641500c0 0x20>;
			gpio-controller;
			#gpio-cells = <2>;
			interrupt-controller;
			#interrupt-cells = <2>;
			interrupts = <GIC_SPI 72 IRQ_TYPE_LEVEL_HIGH>;
