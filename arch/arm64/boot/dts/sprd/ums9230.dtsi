				};
			};
		};

		prometheus7-thermal {
			polling-delay-passive = <250>;

			thermal-sensors = <&ap_thm0 4>;

			trips {
				cpu7_alert0: trip-point0 {
					temperature = <70000>;
					hysteresis = <1000>;
					type = "passive";
				};

				cpu7_critical: cpu-crit {
					temperature = <110000>;
					hysteresis = <2000>;
					type = "critical";
				};
			};

			cooling-maps {
				map0 {
					trip = <&cpu7_alert0>;
					cooling-device = <&cpu7 THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
				};
			};
		};

		cputop1-thermal {
			polling-delay-passive = <250>;

			thermal-sensors = <&ap_thm0 5>;

