		aon_i2c0: i2c@641a0000 {
			compatible = "sprd,ums9230-hw-i2c";
			reg = <0x641a0000 0x10000>;
			interrupts = <GIC_SPI 68 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&aon_gate CLK_I2C_EB>,
				 <&aon_clk CLK_AON_I2C>,
				 <&ext_26m>;
			clock-names = "enable", "i2c", "source";
			clock-frequency = <400000>;

			status = "disabled";
		};

		ap_gpio: gpio@641b0000 {
			compatible = "sprd,ums9230-gpio", "sprd,sc9860-gpio";
			reg = <0x641b0000 0x10000>;
